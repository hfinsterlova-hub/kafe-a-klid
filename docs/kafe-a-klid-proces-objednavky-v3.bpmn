        <dc:Bounds x="270" y="130" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LoginOrRegister_di" bpmnElement="Task_LoginOrRegister">
        <dc:Bounds x="360" y="92" width="130" height="62" />
      </bpmndi:BPMNShape>
