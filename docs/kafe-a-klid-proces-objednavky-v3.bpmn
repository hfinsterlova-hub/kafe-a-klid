        <dc:Bounds x="360" y="164" width="130" height="56" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_AccessMerged_di" bpmnElement="Gateway_AccessMerged" isMarkerVisible="true">
        <dc:Bounds x="540" y="130" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_SelectItems_di" bpmnElement="Task_SelectItems">
        <dc:Bounds x="800" y="120" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_UpdateCartAndStepper_di" bpmnElement="Task_UpdateCartAndStepper">
        <dc:Bounds x="800" y="310" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CompletePayment_di" bpmnElement="Task_CompletePayment">
        <dc:Bounds x="980" y="120" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ProcessPayment_di" bpmnElement="Task_ProcessPayment">
        <dc:Bounds x="980" y="475" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_PaymentSuccessful_di" bpmnElement="Gateway_PaymentSuccessful" isMarkerVisible="true">
        <dc:Bounds x="1140" y="485" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ShowPaymentError_di" bpmnElement="Task_ShowPaymentError">
        <dc:Bounds x="1120" y="335" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CheckStock_di" bpmnElement="Task_CheckStock">
        <dc:Bounds x="1280" y="310" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Gateway_StockAvailable_di" bpmnElement="Gateway_StockAvailable" isMarkerVisible="true">
        <dc:Bounds x="1440" y="320" width="50" height="50" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_ShowStockShortage_di" bpmnElement="Task_ShowStockShortage">
        <dc:Bounds x="1420" y="385" width="130" height="55" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_CreateOrder_di" bpmnElement="Task_CreateOrder">
        <dc:Bounds x="1580" y="310" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_DeductInventory_di" bpmnElement="Task_DeductInventory">
        <dc:Bounds x="1580" y="590" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyOrderAccepted_di" bpmnElement="Task_NotifyOrderAccepted">
        <dc:Bounds x="1740" y="310" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_AcceptOrder_di" bpmnElement="Task_AcceptOrder">
        <dc:Bounds x="1740" y="720" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PrepareOrder_di" bpmnElement="Task_PrepareOrder">
        <dc:Bounds x="1900" y="720" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_MarkReady_di" bpmnElement="Task_MarkReady">
        <dc:Bounds x="2060" y="720" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_NotifyOrderReady_di" bpmnElement="Task_NotifyOrderReady">
        <dc:Bounds x="2060" y="310" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_PickupOrder_di" bpmnElement="Task_PickupOrder">
        <dc:Bounds x="2220" y="120" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_HandOverOrder_di" bpmnElement="Task_HandOverOrder">
        <dc:Bounds x="2220" y="720" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="EndEvent_OrderDone_di" bpmnElement="EndEvent_OrderDone">
        <dc:Bounds x="2420" y="137" width="36" height="36" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Task_LoadOffer_di" bpmnElement="Task_LoadOffer">
        <dc:Bounds x="640" y="295" width="130" height="70" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Flow_Start_Access_di" bpmnElement="Flow_Start_Access">
        <di:waypoint x="226" y="155" />
        <di:waypoint x="270" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Access_Login_di" bpmnElement="Flow_Access_Login">
        <di:waypoint x="295" y="130" />
        <di:waypoint x="295" y="123" />
        <di:waypoint x="360" y="123" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Access_Guest_di" bpmnElement="Flow_Access_Guest">
        <di:waypoint x="295" y="180" />
        <di:waypoint x="295" y="192" />
        <di:waypoint x="360" y="192" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Login_Merge_di" bpmnElement="Flow_Login_Merge">
        <di:waypoint x="490" y="123" />
        <di:waypoint x="540" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Guest_Merge_di" bpmnElement="Flow_Guest_Merge">
        <di:waypoint x="490" y="192" />
        <di:waypoint x="540" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Merge_LoadOffer_di" bpmnElement="Flow_Merge_LoadOffer">
        <di:waypoint x="590" y="155" />
        <di:waypoint x="620" y="155" />
        <di:waypoint x="620" y="330" />
        <di:waypoint x="640" y="330" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Load_Select_di" bpmnElement="Flow_Load_Select">
        <di:waypoint x="770" y="330" />
        <di:waypoint x="785" y="330" />
        <di:waypoint x="785" y="155" />
        <di:waypoint x="800" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Select_UpdateCart_di" bpmnElement="Flow_Select_UpdateCart">
        <di:waypoint x="865" y="190" />
        <di:waypoint x="865" y="310" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_UpdateCart_Pay_di" bpmnElement="Flow_UpdateCart_Pay">
        <di:waypoint x="930" y="345" />
        <di:waypoint x="955" y="345" />
        <di:waypoint x="955" y="155" />
        <di:waypoint x="980" y="155" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_Pay_ProcessPayment_di" bpmnElement="Flow_Pay_ProcessPayment">
        <di:waypoint x="1045" y="190" />
        <di:waypoint x="1045" y="475" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Flow_ProcessPayment_Gateway_di" bpmnElement="Flow_ProcessPayment_Gateway">
        <di:waypoint x="1110" y="510" />
